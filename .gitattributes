# Line ending normalization — prevents CRLF/LF issues across Windows/Mac/Linux
* text=auto

# Force LF for source files
*.py    text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
*.env*  text eol=lf

# Treat as binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
*.gguf  binary
*.pdf   binary
