# ==============================================================================
# Policy AGENT — Environment Configuration
# Copy this file to .env and fill in your values.
# All values here are the documented defaults for local development.
# ==============================================================================

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=policy_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── vLLM Inference Server ──────────────────────────────────────────────────────
# Base URL for the OpenAI-compatible vLLM API (no trailing slash)
VLLM_API_URL=http://localhost:8000/v1

# ── JWT Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Business Logic Thresholds ──────────────────────────────────────────────────
# Impact Engine: minimum score for a document to be added to the active review workspace
IMPACT_SCORE_THRESHOLD=0.4

# Semantic Proximity: minimum cosine similarity to create an OVERLAPS_WITH edge
OVERLAP_SIMILARITY_THRESHOLD=0.88

# Frozen Memory: minimum similarity to serve a cached answer
FROZEN_MEMORY_SIMILARITY_THRESHOLD=0.95

# DBSCAN clustering: max cosine distance within a cluster
DBSCAN_EPS=0.15

# DBSCAN: minimum cluster size to promote to frozen memory
CONSOLIDATION_MIN_SAMPLES=2

# RAG: number of chunks returned after local re-ranking
RERANK_TOP_K=15
